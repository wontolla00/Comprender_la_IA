<script>
// Progress bar
window.addEventListener('scroll', () => {
  const el = document.documentElement;
  document.getElementById('prog-fill').style.width =
    (el.scrollTop / (el.scrollHeight - el.clientHeight) * 100) + '%';
});
// Dark mode toggle
document.querySelectorAll('.topbar button').forEach(btn => {
  btn.addEventListener('click', () => document.body.classList.toggle('dark'));
});
// Checklist
document.addEventListener('click', e => {
  if (e.target.classList.contains('check-box')) {
    e.target.classList.toggle('checked');
    e.target.textContent = e.target.classList.contains('checked') ? '✓' : '';
  }
});
// Active nav links
const sectionIds = [...document.querySelectorAll('[id]')].map(el => el.id);
window.addEventListener('scroll', () => {
  let current = '';
  sectionIds.forEach(id => {
    const el = document.getElementById(id);
    if (el && el.getBoundingClientRect().top < 120) current = id;
  });
  document.querySelectorAll('.topbar-nav a').forEach(a => {
    a.classList.toggle('active', a.getAttribute('href') === '#' + current);
  });
});
</script>
