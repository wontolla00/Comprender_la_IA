.glos-index { display: flex; gap: 6px; flex-wrap: wrap; margin: 20px 0; }
.glos-index a { font-family: system-ui, sans-serif; font-size: .82rem; font-weight: 700; padding: 4px 8px; border: 1px solid var(--border); border-radius: 4px; color: var(--accent); text-decoration: none; transition: all .15s; }
