<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Comprender la IA — Edición 2026</title>
<style>
/* ── Design tokens ─────────────────────────────────────────────────────────── */
:root {
  --accent:       #2563eb;
  --accent-light: #dbeafe;
  --text:         #1e293b;
  --muted:        #64748b;
  --bg:           #f8fafc;
  --border:       #cbd5e1;
  --card-bg:      #ffffff;
  --green:        #16a34a;  --green-light:  #dcfce7;
  --orange:       #ea580c;  --orange-light: #fff7ed;
  --purple:       #7c3aed;  --purple-light: #ede9fe;
  --teal:         #0891b2;  --teal-light:   #e0f2fe;
  --red:          #dc2626;  --red-light:    #fee2e2;
  --yellow:       #ca8a04;  --yellow-light: #fefce8;
  --pink:         #db2777;  --pink-light:   #fce7f3;
  --slate:        #475569;
}

/* ── Dark mode ──────────────────────────────────────────────────────────────── */
body.dark {
  --bg:           #0f172a;
  --text:         #e2e8f0;
  --muted:        #94a3b8;
  --border:       #334155;
  --card-bg:      #1e293b;
  --accent-light: #1e3a5f;
  --green-light:  #052e16;
  --orange-light: #431407;
  --purple-light: #2e1065;
  --teal-light:   #082f49;
  --red-light:    #450a0a;
  --yellow-light: #422006;
  --pink-light:   #500724;
}

/* ── Reset ──────────────────────────────────────────────────────────────────── */
* { box-sizing: border-box; margin: 0; padding: 0; }

/* ── Base ───────────────────────────────────────────────────────────────────── */
body {
  font-family: Georgia, serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.85;
  font-size: 16px;
  transition: background .3s, color .3s;
}
.container {
  max-width: 900px;
  margin: 0 auto;
  padding: 48px 28px 120px;
  background: var(--card-bg);
  border-radius: 0 0 1rem 1rem;
}

/* ── Topbar ─────────────────────────────────────────────────────────────────── */
.topbar {
  position: sticky; top: 0; z-index: 100;
  background: var(--card-bg);
  border-bottom: 1px solid var(--border);
  padding: 10px 28px;
  display: flex; align-items: center; gap: 16px;
  font-family: system-ui, sans-serif; font-size: 13px; flex-wrap: wrap;
}
.topbar-title { font-weight: 700; color: var(--accent); margin-right: auto; }
.topbar-nav { display: flex; gap: 8px; flex-wrap: wrap; }
.topbar-nav a {
  color: var(--muted); text-decoration: none;
  font-size: .78rem; padding: 3px 8px; border-radius: 4px; transition: all .15s;
}
.topbar-nav a:hover,
.topbar-nav a.active { background: var(--accent); color: white; }
.topbar button {
  background: var(--accent-light); border: 1px solid var(--border);
  padding: 4px 10px; border-radius: 6px; cursor: pointer;
  font-size: .8rem; color: var(--text);
}
.topbar button:hover { background: var(--accent); color: white; }

/* ── Progress strip ─────────────────────────────────────────────────────────── */
.progress-strip { height: 4px; background: var(--border); position: sticky; top: 45px; z-index: 99; }
.progress-fill  { height: 100%; background: var(--accent); width: 0%; transition: width .3s; }

/* ── Typography ─────────────────────────────────────────────────────────────── */
h1 { font-size: 1.9rem; margin-bottom: 10px; color: #0f172a; line-height: 1.25; }
h2 { font-size: 1.3rem; margin: 48px 0 14px; color: #0f172a; border-bottom: 2px solid var(--accent-light); padding-bottom: 6px; scroll-margin-top: 80px; }
h3 { font-size: 1.05rem; margin: 32px 0 10px; color: #1e40af; }
h4 { font-size: .95rem; margin: 22px 0 8px; color: var(--text); font-style: italic; }
p  { margin-bottom: 16px; }
ul, ol { margin: 12px 0 16px 28px; }
li { margin-bottom: 7px; }
strong { color: #0f172a; }
body.dark h1, body.dark h2 { color: #f1f5f9; }
body.dark h3 { color: #93c5fd; }
body.dark strong { color: #f1f5f9; }

code {
  background: var(--bg); border: 1px solid var(--border);
  border-radius: 4px; padding: 1px 6px; font-size: .88rem; font-family: monospace;
}
pre {
  background: #0f172a; color: #e2e8f0;
  padding: 20px 24px; border-radius: 8px; overflow-x: auto;
  font-size: .85rem; line-height: 1.6; margin: 20px 0;
}
body.dark pre { background: #1e293b; border: 1px solid var(--border); }

/* ── TOC ────────────────────────────────────────────────────────────────────── */
.toc { background: var(--card-bg); border: 1px solid var(--border); border-radius: 8px; padding: 32px 36px; margin: 40px 0 56px; }
.toc h2 { font-size: 1.2rem; text-transform: uppercase; letter-spacing: .06em; border: none; margin: 0 0 24px; padding: 0; }
.toc-part { margin-bottom: 20px; }
.toc-part-title { font-family: system-ui, sans-serif; font-weight: 700; font-size: .82rem; text-transform: uppercase; letter-spacing: .07em; color: var(--accent); margin-bottom: 6px; }
.toc-item { display: flex; justify-content: space-between; padding: 3px 0; border-bottom: 1px dotted var(--border); font-size: .93rem; }
.toc-item a { color: var(--text); text-decoration: none; }
.toc-item a:hover { color: var(--accent); }

/* ── Hero (portada) ─────────────────────────────────────────────────────────── */
.hero {
  background: linear-gradient(135deg, #1e40af 0%, #2563eb 100%);
  color: white; padding: 40px 40px 36px; border-radius: 12px; margin-bottom: 48px;
}
.hero-tag {
  font-family: system-ui, sans-serif; font-size: .75rem;
  text-transform: uppercase; letter-spacing: .1em;
  background: rgba(255,255,255,.2); display: inline-block;
  padding: 3px 10px; border-radius: 20px; margin-bottom: 14px;
}
.hero h1 { color: white; font-size: 1.8rem; margin-bottom: 10px; }
.hero p  { color: rgba(255,255,255,.85); margin-bottom: 0; font-size: 1.05rem; }
.hero-meta {
  margin-top: 24px; padding-top: 20px;
  border-top: 1px solid rgba(255,255,255,.25);
  font-family: system-ui, sans-serif; font-size: .83rem;
  color: rgba(255,255,255,.7); display: flex; gap: 24px; flex-wrap: wrap;
}
.hero-meta span { display: flex; align-items: center; gap: 6px; }

/* ── Chapter header ─────────────────────────────────────────────────────────── */
.chapter-header {
  color: white; padding: 36px 40px 32px;
  border-radius: 12px; margin: 60px 0 36px; scroll-margin-top: 80px;
  background: linear-gradient(135deg, #0c4a6e, #0891b2); /* cap1 por defecto */
}
.chapter-header.cap1, .chapter-header.c1  { background: linear-gradient(135deg, #0c4a6e, #0891b2); }
.chapter-header.cap2, .chapter-header.c2  { background: linear-gradient(135deg, #1e1b4b, #4338ca); }
.chapter-header.cap3, .chapter-header.c3  { background: linear-gradient(135deg, #14532d, #16a34a); }
.chapter-header.cap4, .chapter-header.c4  { background: linear-gradient(135deg, #4a1942, #9333ea); }
.chapter-header.c5  { background: linear-gradient(135deg, #1e3a5f, #2563eb); }
.chapter-header.c6  { background: linear-gradient(135deg, #0c4a6e, #0891b2); }
.chapter-header.c7  { background: linear-gradient(135deg, #14532d, #16a34a); }
.chapter-header.c8  { background: linear-gradient(135deg, #3b0764, #9333ea); }
.chapter-header.c9  { background: linear-gradient(135deg, #7c2d12, #ea580c); }
.chapter-header.c10 { background: linear-gradient(135deg, #1c1917, #44403c); }
.chapter-header.c11 { background: linear-gradient(135deg, #7f1d1d, #dc2626); }
.chapter-header.c12 { background: linear-gradient(135deg, #1e3a5f, #2563eb); }
.chapter-header.c13 { background: linear-gradient(135deg, #14532d, #16a34a); }
.chapter-header.c14 { background: linear-gradient(135deg, #3b0764, #9333ea); }
.chapter-header.c15 { background: linear-gradient(135deg, #0c4a6e, #0891b2); }
.chapter-header.c16 { background: linear-gradient(135deg, #1c1917, #78716c); }
.chapter-header.c17 { background: linear-gradient(135deg, #1e3a5f, #2563eb); }
.chapter-header.c18 { background: linear-gradient(135deg, #14532d, #16a34a); }
.chapter-header.c19 { background: linear-gradient(135deg, #4a1942, #db2777); }
.chapter-header.c20 { background: linear-gradient(135deg, #1c1917, #292524); }
.chapter-header.c21 { background: linear-gradient(135deg, #1e1b4b, #4338ca); }
.chapter-header.cglos { background: linear-gradient(135deg, #14532d, #166534); }
.chapter-tag {
  font-family: system-ui, sans-serif; font-size: .72rem;
  text-transform: uppercase; letter-spacing: .1em;
  background: rgba(255,255,255,.2); display: inline-block;
  padding: 3px 10px; border-radius: 20px; margin-bottom: 12px;
}
.chapter-header h1 { color: white; font-size: 1.6rem; margin-bottom: 8px; }
.chapter-subtitle { color: rgba(255,255,255,.82); font-size: 1rem; margin-bottom: 0; }
.chapter-meta {
  margin-top: 20px; padding-top: 16px;
  border-top: 1px solid rgba(255,255,255,.2);
  font-family: system-ui, sans-serif; font-size: .8rem;
  color: rgba(255,255,255,.7); display: flex; gap: 20px; flex-wrap: wrap;
}

/* ── Callouts ───────────────────────────────────────────────────────────────── */
.callout, .warning, .success, .experimento, .hilo, .nuevo, .alerta, .nota, .autor {
  padding: 14px 18px; margin: 22px 0;
  border-left: 4px solid; border-radius: 0 6px 6px 0; font-size: .95rem;
}
.callout     { background: var(--accent-light);  border-color: var(--accent); }
.warning     { background: var(--orange-light);  border-color: var(--orange); }
.success     { background: var(--green-light);   border-color: var(--green); }
.experimento { background: var(--teal-light);    border-color: var(--teal); }
.hilo        { background: var(--purple-light);  border-color: var(--purple); }
.nuevo, .alerta { background: var(--red-light);  border-color: var(--red); }
.nota, .autor   { background: var(--yellow-light); border-color: var(--yellow); }

.callout strong     { color: #1e40af; }
.warning strong     { color: #c2410c; }
.success strong     { color: var(--green); }
.experimento strong { color: var(--teal); }
.hilo strong        { color: var(--purple); }
.nuevo strong, .alerta strong { color: var(--red); }
.nota strong, .autor strong   { color: var(--yellow); }

.callout strong, .warning strong, .success strong,
.experimento strong, .hilo strong, .nuevo strong,
.alerta strong, .nota strong, .autor strong {
  display: block; margin-bottom: 4px;
  font-family: system-ui, sans-serif; font-size: .82rem;
  text-transform: uppercase; letter-spacing: .04em;
}

body.dark .callout     { background: #1e293b; }
body.dark .warning     { background: #2d1f0c; }
body.dark .success     { background: #052e16; }
body.dark .experimento { background: #082f49; }
body.dark .hilo        { background: #2e1065; }
body.dark .nuevo, body.dark .alerta { background: #450a0a; }
body.dark .nota, body.dark .autor   { background: #422006; }

/* ── Tables ─────────────────────────────────────────────────────────────────── */
table { width: 100%; border-collapse: collapse; margin: 22px 0; font-size: .87rem; font-family: system-ui, sans-serif; border: 1px solid var(--border); }
th { background: #334155; color: #f1f5f9; padding: 9px 12px; text-align: left; border: 1px solid #475569; font-weight: 600; }
td { padding: 8px 12px; border: 1px solid var(--border); vertical-align: top; background: var(--card-bg); }
tr:nth-child(even) td { background: var(--bg); }
td:first-child { font-weight: 600; color: var(--accent); }
body.dark td:first-child { color: #93c5fd; }

/* ── Tags / badges ──────────────────────────────────────────────────────────── */
.tag {
  font-family: system-ui, sans-serif; font-size: .75rem;
  padding: 2px 8px; border-radius: 20px;
  background: var(--accent-light); color: #1e40af; font-weight: 600;
}
body.dark .tag { background: #1e3a5f; color: #93c5fd; }
.tag.verde   { background: var(--green-light);  color: var(--green); }
.tag.naranja { background: var(--orange-light); color: var(--orange); }
.tag.morado  { background: var(--purple-light); color: var(--purple); }

.badge { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: .75rem; font-family: system-ui, sans-serif; font-weight: 700; }
.badge.new  { background: var(--red-light);    color: var(--red); }
.badge.ok   { background: var(--green-light);  color: var(--green); }
.badge.warn { background: var(--orange-light); color: var(--orange); }

/* ── Part header ────────────────────────────────────────────────────────────── */
.part-header { background: #1e40af; color: white; padding: 20px 28px; border-radius: 8px; margin: 56px 0 8px; font-family: system-ui, sans-serif; }
.part-header p { color: rgba(255,255,255,.8); margin: 6px 0 0; font-size: .9rem; }

/* ── Module hero ────────────────────────────────────────────────────────────── */
.modulo-hero { color: white; padding: 40px 40px 36px; border-radius: 12px; margin-bottom: 40px; }
.modulo-hero h1 { color: white; font-size: 2rem; margin-bottom: 8px; }
.modulo-hero p  { color: rgba(255,255,255,.85); margin-bottom: 0; }
.modulo-hero.m1 { background: linear-gradient(135deg, #1e40af, #2563eb); }
.modulo-hero.m2 { background: linear-gradient(135deg, #312e81, #4338ca); }
.modulo-hero.m3 { background: linear-gradient(135deg, #7f1d1d, #b91c1c); }
.modulo-hero.m4 { background: linear-gradient(135deg, #1e3a5f, #1d4ed8 50%, #7c3aed); }
.modulo-hero.m5 { background: linear-gradient(135deg, #1c1917, #292524 60%, #1e1b4b); }
.modulo-meta {
  margin-top: 20px; padding-top: 16px;
  border-top: 1px solid rgba(255,255,255,.25);
  font-family: system-ui, sans-serif; font-size: .82rem;
  color: rgba(255,255,255,.7); display: flex; gap: 20px; flex-wrap: wrap;
}

/* ── Reading routes ─────────────────────────────────────────────────────────── */
.rutas { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin: 32px 0; }
.ruta-card { border: 2px solid var(--border); border-radius: 10px; padding: 22px; background: var(--card-bg); transition: border-color .2s; }
.ruta-card:hover { border-color: var(--accent); }
.ruta-card.active { border-color: var(--accent); background: var(--accent-light); }
.ruta-icon  { font-size: 1.8rem; margin-bottom: 10px; }
.ruta-title { font-family: system-ui, sans-serif; font-weight: 700; font-size: .95rem; margin-bottom: 6px; color: #1e40af; }
.ruta-desc  { font-size: .88rem; color: var(--muted); font-family: system-ui, sans-serif; margin-bottom: 12px; }
.ruta-caps  { font-family: monospace; font-size: .82rem; background: var(--bg); padding: 6px 10px; border-radius: 6px; color: var(--text); border: 1px solid var(--border); }
body.dark .ruta-title { color: #93c5fd; }

/* ── Module list ────────────────────────────────────────────────────────────── */
.modulos { margin: 32px 0; }
.modulo-item { display: flex; gap: 16px; align-items: flex-start; padding: 16px 0; border-bottom: 1px solid var(--border); }
.modulo-item:last-child { border-bottom: none; }
.modulo-num {
  flex-shrink: 0; width: 40px; height: 40px;
  background: var(--accent); color: white; border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-family: system-ui, sans-serif; font-weight: 700; font-size: .95rem;
}
.modulo-num.m0 { background: #64748b; }
.modulo-num.m1 { background: #0891b2; }
.modulo-num.m2 { background: #2563eb; }
.modulo-num.m3 { background: #7c3aed; }
.modulo-num.m4 { background: #16a34a; }
.modulo-num.m5 { background: #334155; }
.modulo-info  { flex: 1; }
.modulo-title { font-family: system-ui, sans-serif; font-weight: 700; font-size: .95rem; margin-bottom: 4px; }
.modulo-desc  { font-size: .88rem; color: var(--muted); font-family: system-ui, sans-serif; margin-bottom: 6px; }
.modulo-tags  { display: flex; gap: 6px; flex-wrap: wrap; }

/* ── Bridge diagram ─────────────────────────────────────────────────────────── */
.puente { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; margin: 32px 0; font-family: system-ui, sans-serif; }
.puente-lado { background: var(--bg); border: 1px solid var(--border); border-radius: 10px; padding: 18px; }
.puente-lado h4 { font-size: .82rem; text-transform: uppercase; letter-spacing: .06em; color: var(--muted); margin-bottom: 10px; }
.puente-lado ul { margin: 0; padding-left: 16px; font-size: .88rem; }
.puente-lado li { margin-bottom: 4px; color: var(--text); }
.puente-flecha  { text-align: center; padding: 0 16px; font-size: 1.8rem; color: var(--accent); }
.puente-lado.destino { border-color: var(--accent); background: var(--accent-light); }
.puente-lado.destino li { color: #1e40af; }
body.dark .puente-lado.destino li { color: #93c5fd; }

/* ── Checklist ──────────────────────────────────────────────────────────────── */
.checklist { margin: 20px 0; }
.check-item, .checklist-item {
  display: flex; gap: 12px; align-items: flex-start;
  padding: 10px 0; border-bottom: 1px solid var(--border); font-size: .93rem;
}
.check-item:last-child, .checklist-item:last-child { border-bottom: none; }
.check-box {
  flex-shrink: 0; width: 20px; height: 20px;
  border: 2px solid var(--border); border-radius: 4px; margin-top: 3px;
  cursor: pointer; transition: all .15s;
  display: flex; align-items: center; justify-content: center; font-size: 12px;
}
.check-box.checked { background: var(--green); border-color: var(--green); color: white; }

/* ── Progress bar (inline) ──────────────────────────────────────────────────── */
.progress-bar-container { background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 16px 20px; margin: 32px 0; font-family: system-ui, sans-serif; }
.progress-label { font-size: .83rem; color: var(--muted); margin-bottom: 8px; display: flex; justify-content: space-between; }
.progress-bar   { height: 8px; background: var(--border); border-radius: 4px; overflow: hidden; }

/* ── Tiempo badge ───────────────────────────────────────────────────────────── */
.tiempo-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--accent-light); color: #1e40af;
  font-family: system-ui, sans-serif; font-size: .8rem; font-weight: 600;
  padding: 4px 12px; border-radius: 20px; margin-bottom: 24px;
}
body.dark .tiempo-badge { background: #1e3a5f; color: #93c5fd; }

/* ── Resultado final ────────────────────────────────────────────────────────── */
.resultado-final { border: 2px solid var(--accent); border-radius: 12px; padding: 24px 28px; margin: 48px 0 32px; background: var(--accent-light); }
.resultado-final h3 { margin-top: 0; color: #1e40af; font-size: 1rem; font-style: normal; }
body.dark .resultado-final { background: #1e3a5f; border-color: #3b82f6; }
body.dark .resultado-final h3 { color: #93c5fd; }

/* ── Profile highlight ──────────────────────────────────────────────────────── */
.perfil-highlight { border: 2px solid var(--accent); border-radius: 10px; padding: 20px 24px; margin: 24px 0; background: var(--accent-light); }
.perfil-highlight h3 { margin-top: 0; color: #1e40af; }
body.dark .perfil-highlight h3 { color: #93c5fd; }

/* ── Nav caps ───────────────────────────────────────────────────────────────── */
.nav-caps { display: flex; gap: 12px; margin: 40px 0; flex-wrap: wrap; }
.nav-cap {
  flex: 1; min-width: 180px; border: 1px solid var(--border); border-radius: 8px;
  padding: 14px 18px; font-family: system-ui, sans-serif; font-size: .85rem;
  color: var(--text); text-decoration: none; transition: all .15s;
  background: var(--card-bg); cursor: pointer; display: block;
}
.nav-cap:hover { border-color: var(--accent); background: var(--accent-light); }
.nav-cap .nav-dir   { font-size: .75rem; color: var(--muted); margin-bottom: 4px; }
.nav-cap .nav-title { font-weight: 700; color: var(--accent); }

/* ── Separator ──────────────────────────────────────────────────────────────── */
.sep { border: none; border-top: 1px solid var(--border); margin: 48px 0; }

/* ── Comparativa ────────────────────────────────────────────────────────────── */
.comparativa { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 28px 0; }
.comp-lado { border: 1px solid var(--border); border-radius: 10px; padding: 20px; background: var(--card-bg); }
.comp-lado.a { border-top: 4px solid #64748b; }
.comp-lado.b { border-top: 4px solid var(--accent); }
.comp-lado h4 { margin-top: 0; font-style: normal; font-family: system-ui, sans-serif; font-size: .8rem; text-transform: uppercase; letter-spacing: .06em; color: var(--muted); margin-bottom: 12px; }
.comp-lado ul { margin: 0; padding-left: 18px; }
.comp-lado li { font-size: .9rem; margin-bottom: 6px; }
@media (max-width: 640px) { .comparativa { grid-template-columns: 1fr; } }

/* ── Pipeline visual ────────────────────────────────────────────────────────── */
.pipeline { display: flex; align-items: center; margin: 28px 0; flex-wrap: wrap; justify-content: center; }
.pipe-step {
  background: var(--card-bg); border: 2px solid var(--border);
  border-radius: 8px; padding: 12px 16px; text-align: center;
  font-family: system-ui, sans-serif; min-width: 100px;
}
.pipe-step.hi   { border-color: var(--accent); background: var(--accent-light); }
.pipe-step.det  { border-color: var(--green);  background: var(--green-light); }
.pipe-step.warn { border-color: var(--orange); background: var(--orange-light); }
.pipe-step .pi  { font-size: 1.4rem; display: block; margin-bottom: 4px; }
.pipe-step .pl  { font-size: .75rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; }
.pipe-step.hi .pl   { color: var(--accent); }
.pipe-step.det .pl  { color: var(--green); }
.pipe-step.warn .pl { color: var(--orange); }
.pipe-step .ps  { font-size: .7rem; color: var(--muted); margin-top: 2px; }
.pipe-arrow { color: var(--muted); font-size: 1.2rem; padding: 0 4px; }
