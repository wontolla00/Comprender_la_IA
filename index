/* ── Tooltip ────────────────────────────────────────────────────────────────── */
.gt { background: var(--accent-light); color: #1e40af; border-bottom: 1.5px dashed var(--accent); cursor: pointer; border-radius: 2px; padding: 0 2px; position: relative; }
.gt .tt {
  display: none; position: absolute; bottom: calc(100% + 8px); left: 50%;
  transform: translateX(-50%); background: #0f172a; color: #f1f5f9;
  font-family: system-ui, sans-serif; font-size: .78rem; line-height: 1.5;
  padding: 8px 12px; border-radius: 6px; width: 240px;
  box-shadow: 0 4px 16px rgba(0,0,0,.25); z-index: 9999; pointer-events: none;
}
.gt .tt::after { content: ''; position: absolute; top: 100%; left: 50%; transform: translateX(-50%); border: 6px solid transparent; border-top-color: #0f172a; }
.gt:hover .tt { display: block; }

/* ── Criticality levels ─────────────────────────────────────────────────────── */
.niveles { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 16px; margin: 28px 0; }
.nivel-card { border-radius: 10px; padding: 18px 20px; font-family: system-ui, sans-serif; }
.nivel-card h4 { font-size: .88rem; font-weight: 700; font-style: normal; margin: 0 0 6px; }
.nivel-card p  { font-size: .82rem; margin: 0; }
.n1 { background: var(--green-light);  border-left: 4px solid var(--green); }  .n1 h4 { color: var(--green); }
.n2 { background: var(--yellow-light); border-left: 4px solid var(--yellow); } .n2 h4 { color: var(--yellow); }
.n3 { background: var(--orange-light); border-left: 4px solid var(--orange); } .n3 h4 { color: var(--orange); }
.n4 { background: var(--red-light);    border-left: 4px solid var(--red); }    .n4 h4 { color: var(--red); }
body.dark .n1 { background: #052e16; } body.dark .n2 { background: #422006; }
body.dark .n3 { background: #431407; } body.dark .n4 { background: #450a0a; }

/* ── Role cards ─────────────────────────────────────────────────────────────── */
.roles-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin: 32px 0; }
.rol-card { border: 2px solid var(--border); border-radius: 12px; padding: 24px; background: var(--card-bg); transition: border-color .2s; }
.rol-card:hover { border-color: var(--accent); }
.rol-card .rol-icon    { font-size: 2rem; margin-bottom: 12px; display: block; }
.rol-card .rol-nombre  { font-family: system-ui, sans-serif; font-weight: 800; font-size: 1rem; color: #0f172a; margin-bottom: 4px; }
body.dark .rol-card .rol-nombre { color: #f1f5f9; }
.rol-card .rol-tag     { display: inline-block; font-family: system-ui, sans-serif; font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; padding: 2px 8px; border-radius: 20px; margin-bottom: 10px; }
.rol-card .rol-desc    { font-size: .88rem; color: var(--muted); font-family: system-ui, sans-serif; margin-bottom: 12px; }
.rol-card .rol-superpoder { font-size: .87rem; border-top: 1px solid var(--border); padding-top: 10px; margin-top: 4px; }
.rol-card .rol-superpoder strong { font-family: system-ui, sans-serif; font-size: .75rem; text-transform: uppercase; letter-spacing: .05em; display: block; margin-bottom: 4px; color: var(--muted); }

/* ── Transition steps ───────────────────────────────────────────────────────── */
.transicion-barra { display: flex; flex-direction: column; gap: 16px; margin: 28px 0; }
.paso-transicion  { display: flex; gap: 16px; align-items: flex-start; }
.paso-num {
  flex-shrink: 0; width: 36px; height: 36px;
  background: var(--accent); color: white; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-family: system-ui, sans-serif; font-weight: 700; font-size: .9rem; margin-top: 2px;
}
.paso-content h4 { margin-top: 0; font-style: normal; font-family: system-ui, sans-serif; font-weight: 700; font-size: .95rem; color: var(--text); margin-bottom: 6px; }
.paso-content p  { margin: 0; font-size: .9rem; color: var(--muted); font-family: system-ui, sans-serif; }

/* ── Project portfolio cards ────────────────────────────────────────────────── */
.proyecto-card   { border: 1px solid var(--border); border-radius: 10px; padding: 20px 22px; margin: 16px 0; background: var(--card-bg); }
.proyecto-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; flex-wrap: wrap; gap: 8px; }
.proyecto-titulo { font-family: system-ui, sans-serif; font-weight: 700; font-size: .95rem; }
.proyecto-nivel  { font-family: system-ui, sans-serif; font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; padding: 2px 10px; border-radius: 20px; }
.n-basico   { background: var(--green-light);  color: var(--green); }
.n-medio    { background: var(--yellow-light); color: var(--yellow); }
.n-avanzado { background: var(--orange-light); color: var(--orange); }
.proyecto-desc   { font-size: .88rem; color: var(--muted); font-family: system-ui, sans-serif; margin-bottom: 10px; }
.proyecto-skills { display: flex; gap: 6px; flex-wrap: wrap; }
.skill-tag { font-family: system-ui, sans-serif; font-size: .73rem; font-weight: 600; padding: 2px 8px; border-radius: 4px; background: var(--accent-light); color: var(--accent); }
body.dark .skill-tag { background: #1e3a5f; color: #93c5fd; }

/* ── Transition map ─────────────────────────────────────────────────────────── */
.mapa-transicion { display: grid; grid-template-columns: 1fr auto 1fr; align-items: start; margin: 28px 0; }
.mapa-lado { border: 1px solid var(--border); border-radius: 10px; padding: 18px 20px; background: var(--card-bg); }
.mapa-lado.origen  { border-top: 4px solid #64748b; }
.mapa-lado.destino { border-top: 4px solid var(--accent); }
.mapa-lado h4 { margin-top: 0; font-style: normal; font-family: system-ui, sans-serif; font-size: .8rem; text-transform: uppercase; letter-spacing: .06em; color: var(--muted); margin-bottom: 12px; }
.mapa-flecha  { display: flex; align-items: center; justify-content: center; padding: 0 16px; font-size: 1.8rem; color: var(--accent); }
.mapa-lado ul { margin: 0; padding-left: 18px; }
.mapa-lado li { font-size: .88rem; margin-bottom: 5px; }
@media (max-width: 640px) { .mapa-transicion { grid-template-columns: 1fr; } .mapa-flecha { transform: rotate(90deg); padding: 8px 0; } }

/* ── Timeline ───────────────────────────────────────────────────────────────── */
.timeline { position: relative; margin: 28px 0; padding-left: 28px; }
.timeline::before { content: ''; position: absolute; left: 8px; top: 0; bottom: 0; width: 2px; background: var(--border); }
.timeline-item { position: relative; margin-bottom: 28px; }
.timeline-item::before { content: ''; position: absolute; left: -24px; top: 6px; width: 12px; height: 12px; border-radius: 50%; background: var(--accent); border: 2px solid var(--card-bg); box-shadow: 0 0 0 2px var(--accent); }
.timeline-mes    { font-family: system-ui, sans-serif; font-size: .72rem; text-transform: uppercase; letter-spacing: .08em; color: var(--accent); font-weight: 700; margin-bottom: 4px; }
.timeline-titulo { font-family: system-ui, sans-serif; font-weight: 700; font-size: .95rem; margin-bottom: 4px; }
.timeline-desc   { font-size: .88rem; color: var(--muted); font-family: system-ui, sans-serif; }

/* ── Author concepts ────────────────────────────────────────────────────────── */
.concepto-autor { border: 2px solid var(--yellow); border-radius: 12px; padding: 24px 28px; margin: 28px 0; background: var(--yellow-light); }
.concepto-autor .concepto-badge  { display: inline-block; font-family: system-ui, sans-serif; font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; background: var(--yellow); color: white; padding: 3px 10px; border-radius: 20px; margin-bottom: 10px; }
.concepto-autor .concepto-nombre { font-family: system-ui, sans-serif; font-weight: 800; font-size: 1.1rem; color: #0f172a; margin-bottom: 6px; }
body.dark .concepto-autor .concepto-nombre { color: #f1f5f9; }
.concepto-autor .concepto-def { font-size: .95rem; margin-bottom: 12px; }
.concepto-autor .concepto-estado { font-family: system-ui, sans-serif; font-size: .82rem; color: var(--muted); border-top: 1px solid rgba(0,0,0,.1); padding-top: 10px; margin-top: 4px; }
body.dark .concepto-autor { background: #422006; border-color: #a16207; }
body.dark .concepto-autor .concepto-badge { background: #a16207; }
body.dark .concepto-autor .concepto-estado { border-color: rgba(255,255,255,.1); }

/* ── Glossary ───────────────────────────────────────────────────────────────── */
.glosario { margin-top: 16px; }
.gterm { padding: 16px 0; border-bottom: 1px solid var(--border); scroll-margin-top: 80px; }
.gterm:last-child { border-bottom: none; }
.gterm-header { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; margin-bottom: 6px; flex-wrap: wrap; }
.gterm-nombre { font-family: system-ui, sans-serif; font-weight: 700; color: #1e40af; font-size: .98rem; }
body.dark .gterm-nombre { color: #93c5fd; }
.gterm-en  { font-family: system-ui, sans-serif; font-size: .78rem; color: var(--muted); font-style: italic; }
.gterm-cat { font-family: system-ui, sans-serif; font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; padding: 1px 7px; border-radius: 10px; }
.cat-fundamentos   { background: var(--accent-light); color: var(--accent); }
.cat-arquitectura  { background: var(--teal-light);   color: var(--teal); }
