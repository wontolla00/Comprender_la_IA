  <tr><td>Funcional</td><td>Misma utilidad para el usuario</td><td>Generalmente alcanzable</td></tr>
  <tr><td>Estadística</td><td>Misma distribución de resultados en N ejecuciones</td><td>Siempre posible</td></tr>
</table>

